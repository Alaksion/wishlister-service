NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/wishlister
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me

AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: override the public URL prefix for uploaded objects
# S3_PUBLIC_URL_PREFIX=https://cdn.example.com/

# Optional: use an S3-compatible local endpoint such as MinIO
# S3_ENDPOINT=http://localhost:9000
